{
  "name": "stockflows",
  "version": "1.0.0",
  "description": "Inventory management and demand forecasting for Shopify merchants",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "remix-serve ./build/server/index.js",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:e2e": "playwright test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:push": "prisma db push",
    "db:seed": "tsx scripts/seed.ts",
    "db:seed:demo": "tsx prisma/seed.demo.ts",
    "deploy:tour": "wrangler pages deploy public --project-name=stockflows-tour --branch=main",
    "demo:dev": "turbo run dev --filter=@stockflows/demo",
    "demo:build": "pnpm --filter @stockflows/demo build",
    "ui:dev": "turbo run dev --filter=@stockflows/ui",
    "ui:build": "turbo run build --filter=@stockflows/ui",
    "website:dev": "pnpm --filter @stockflows/website dev",
    "website:build": "pnpm --filter @stockflows/website build",
    "build:pages": "bash scripts/build-pages.sh",
    "build:website": "mkdir -p pages-dist && cp -r website/* pages-dist/ 2>/dev/null || echo 'website/ not yet created, skipping'",
    "build:demo": "pnpm --filter @stockflows/demo build 2>/dev/null && mkdir -p pages-dist/demo && cp -r demo/dist/* pages-dist/demo/ 2>/dev/null || echo 'demo/ not yet created, skipping'",
    "assemble:pages-dist": "echo 'Pages dist assembled successfully'"
  },
  "keywords": [
    "shopify",
    "inventory",
    "forecasting",
    "ecommerce"
  ],
  "author": "StockFlows",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@prisma/client": "^6.8.2",
    "@remix-run/dev": "^2.17.5",
    "@shopify/polaris-tokens": "^8.10.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "18.3.0",
    "@types/react-dom": "18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.5.0",
    "msw": "^2.14.6",
    "playwright": "^1.61.1",
    "prettier": "^3.8.4",
    "prisma": "^6.8.2",
    "tailwindcss": "^4.3.1",
    "turbo": "^2.3.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "@react-email/components": "^1.0.12",
    "@remix-run/serve": "^2.17.5",
    "@sentry/remix": "^10.63.0",
    "@shopify/shopify-api": "^13.1.0",
    "@shopify/shopify-app-remix": "^4.2.1",
    "@shopify/shopify-app-session-storage": "^5.0.1",
    "bullmq": "^5.79.2",
    "csv-parse": "^7.0.1",
    "csv-stringify": "^6.8.1",
    "html5-qrcode": "^2.3.8",
    "isbot": "^5.1.44",
    "pino": "^10.3.1",
    "recharts": "^3.8.1",
    "resend": "^6.17.1",
    "simple-statistics": "^7.9.3",
    "twilio": "^6.0.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  }
}