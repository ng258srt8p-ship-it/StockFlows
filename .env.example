# ─── Shopify App Credentials ─────────────────────────────────────────────────
# Obtained from your Shopify Partner Dashboard > App > API credentials.

SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here

# Comma-separated scopes (must match shopify.app.toml).
SCOPES=read_inventory,write_inventory,read_products,write_products,read_locations,read_orders,read_customers,read_companies,read_report_analytics,write_content

# Public-facing URL of your app (including https://).
# In development this is typically a tunnel URL (e.g. ngrok, cloudflared).
SHOPIFY_APP_URL=https://your-app-url.ngrok.io

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string used by Prisma.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stockpulse_dev?schema=public

# Direct connection (bypasses connection pooler; used by Prisma Migrate).
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/stockpulse_dev?schema=public

# ─── Redis (BullMQ job queue + caching) ─────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Application ─────────────────────────────────────────────────────────────
# "development" | "production" | "test"
NODE_ENV=development

# Log level: "debug" | "info" | "warn" | "error"
LOG_LEVEL=debug

# ─── AI (OpenCode) ──────────────────────────────────────────────────────────
# Required for AI insights feature. Uses OpenCode API with Big Pickle model.
OPENCODE_API_KEY=
OPENCODE_MODEL=big-pickle
OPENCODE_API_URL=https://opencode.ai/api/v1/chat/completions

# ─── Sentry (error tracking) ────────────────────────────────────────────────
# Optional -- leave blank to disable.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ─── Email (Resend) ─────────────────────────────────────────────────────────
# Optional -- used for alert emails and notifications.
RESEND_API_KEY=
RESEND_FROM_EMAIL=StockFlows <notifications@stockflows.app>
